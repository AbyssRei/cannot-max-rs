import { Button, VerticalBox, HorizontalBox, LineEdit, ComboBox } from "std-widgets.slint";

export struct MonsterSelectItem {
    name: string,
    count: int,
    side: string,
}

export component InputPanel inherits VerticalLayout {
    in property <[MonsterSelectItem]> monster-list: [];
    in property <int> selected-count: 1;
    callback request-add-left(string, int);
    callback request-add-right(string, int);
    callback request-confirm();
    callback request-cancel();

    padding: 12px;
    spacing: 8px;

    Text {
        text: "对局阵容输入";
        font-size: 16px;
        font-weight: 700;
    }

    HorizontalLayout {
        spacing: 8px;
        Text {
            text: "怪物: ";
            vertical-alignment: center;
        }
        ComboBox {
            model: ["选择怪物"];
            width: 200px;
        }
        Text {
            text: "数量: ";
            vertical-alignment: center;
        }
        LineEdit {
            text: "1";
            input-type: number;
            width: 60px;
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Button {
            text: "添加到左方";
            clicked => { }
        }
        Button {
            text: "添加到右方";
            clicked => { }
        }
    }

    HorizontalLayout {
        spacing: 8px;
        for item in root.monster-list: HorizontalLayout {
            Text {
                text: item.side == "left" ? "左" : "右";
                font-size: 12px;
                color: item.side == "left" ? #1a73e8 : #dc3545;
            }
            Text {
                text: item.name;
                font-size: 12px;
            }
            Text {
                text: "x" + item.count;
                font-size: 12px;
                font-weight: 700;
            }
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Button {
            text: "确认";
            clicked => { root.request-confirm(); }
        }
        Button {
            text: "取消";
            clicked => { root.request-cancel(); }
        }
    }
}
